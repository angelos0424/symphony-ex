# GitHub auth
# Personal access token or GitHub App token with enough permissions for:
# - issues: read/write
# - pull requests metadata if needed later
# - project read/write (Project v2)
# - repository metadata
GITHUB_TOKEN=

# Target repository
GITHUB_OWNER=
GITHUB_REPO=

# GitHub Project v2 number (optional for issue-only tests, recommended for project-backed pickup/status sync)
GITHUB_PROJECT_NUMBER=

# Optional explicit issue-first test target
# Examples: 123 or ISSUE-123 depending on how you choose to feed identifiers in runtime wiring
GITHUB_ISSUE_IDENTIFIER=
ISSUE_IDENTIFIER=

# Optional API overrides
# Usually leave defaults unless using GHES or custom endpoints
GITHUB_API_URL=https://api.github.com
GITHUB_GRAPHQL_URL=https://api.github.com/graphql

# Workspace/runtime paths
# WORKSPACE_ROOT is where per-issue git worktrees will be created.
# If omitted, SymphonyEx defaults to ./.symphony/worktrees.
# SOURCE_REPO_PATH is the advanced override and wins if explicitly set.
# SOURCE_REPO_URL is the simpler bootstrap option: SymphonyEx clones/fetches it into
# SOURCE_CACHE_ROOT (default: ./.symphony/source-cache/<repo-name>) and then uses that
# resolved local clone as SOURCE_REPO_PATH for git worktree operations.
WORKSPACE_ROOT=
SOURCE_REPO_PATH=
SOURCE_REPO_URL=
SOURCE_CACHE_ROOT=

# Lifecycle/project status names are configured in WORKFLOW.md front matter
# (`tracker.active_states`, `tracker.terminal_states`, and `tracker.lifecycle`),
# not via dedicated GITHUB_*_STATUS env vars.

# Optional dispatch/gating labels for richer parallel-dispatch behavior
# Examples only; actual behavior depends on issue labels in GitHub.
# PRIORITY_LABEL_EXAMPLES=p0,p1,severity:critical
# BLOCKING_LABEL_EXAMPLES=blocked,needs-human
# CONFLICT_SCOPE_LABEL_EXAMPLES=scope:auth,service:billing,path:src/api,package:web,release:v1

# Optional dashboard
# If enabled, you must also set SYMPHONY_DASHBOARD_SECRET_KEY_BASE.
# Generate a long random value, for example:
#   openssl rand -hex 32
SYMPHONY_DASHBOARD_ENABLED=false
SYMPHONY_DASHBOARD_PORT=4000
SYMPHONY_DASHBOARD_HOST=127.0.0.1
SYMPHONY_DASHBOARD_SECRET_KEY_BASE=
