# Shared runtime settings for all SymphonyEx containers.
# Copy to common.env and set a token that can access the target repositories/projects.
GITHUB_TOKEN=replace-with-github-token
TZ=Asia/Seoul
SYMPHONY_LOG_FORMAT=json
SYMPHONY_LOG_LEVEL=info
SYMPHONY_LOG_METADATA=issue_identifier,thread_id,turn_id,outcome_kind,gating_reason,class,conflict_keys
SYMPHONY_LOG_REDACT_KEYS=token,authorization,password,secret,key
SYMPHONY_LOG_MAX_METADATA_VALUE_LENGTH=500
